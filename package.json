{
  "name": "lpi-projects",
  "version": "2.1.2",
  "private": true,
  "description": "LPI projects",
  "author": {
    "name": "LPI IT team"
  },
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --inspect",
    "generate": "nuxt generate",
    "preview": "PORT=8080 nuxt preview",
    "postinstall": "nuxt prepare",
    "build:sourcemaps": "nuxt build --sourcemap",
    "build:report": "trash report && vue-cli-service build",
    "test:unit": "vitest",
    "test:unit:ci": "node  ./node_modules/.bin/vitest ",
    "test:play": "npx playwright test playwright/ --project=chromium ",
    "test:play:dev": "NODE_OPTIONS='--no-experimental-strip-types' npx playwright test playwright/ --project=chromium --trace retain-on-first-failure --retries 0 tests/playwright",
    "test:play:landing": "NODE_OPTIONS='--no-experimental-strip-types' npx playwright test landing/ --project=chromium --trace retain-on-first-failure --retries 0",
    "test:play:gen": "npx playwright codegen --ignore-https-errors http://localhost:8080",
    "test:play:chromium": "npx playwright test playwright/ --project=chromium",
    "lint:ci": "yarn run lint:ci:js && yarn run lint:ci:scss && yarn run check-types",
    "lint:ci:js": "node ./node_modules/.bin/eslint --ext .js,.vue,.ts src",
    "lint:ci:scss": "node ./node_modules/.bin/stylelint -c .stylelintrc.json \"**/*.{vue,scss,sass,css}\" --ignore-path .gitignore",
    "lint": "yarn run lint:js && yarn run lint:scss && yarn run check-types",
    "lint:js": "eslint --ext .js,.vue,.ts --fix src",
    "lint:js:test": "eslint --ext .js,.vue,.ts --fix test",
    "lint:scss": "stylelint \"**/*.{vue,scss,sass,css}\" --ignore-path .gitignore --fix",
    "check-types": "nuxt typecheck --cwd ./src",
    "format": "prettier --ignore-path .gitignore --write \"**/*.{json,js,ts,vue,scss,sass,css}\"",
    "format:check": "prettier --ignore-path .gitignore --check \"**/*.{json,js,ts,vue,scss,sass,css}\"",
    "format:write": "prettier --ignore-path .gitignore --check \"**/*.{json,js,ts,vue,scss,sass,css}\" --write",
    "i18n:report": "vue-cli-service i18n:report --src \"./src/**/*.?(js|vue)\" --locales \"./src/locales/**/*.json\"",
    "prepare": "husky install",
    "check-unused-comp": "check-unused-comp .",
    "vue-i18n-extract": "vue-i18n-extract report --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/i18n/locales/*.?(json|yml|yaml|js)'",
    "list-icons": "node ./utilities/list-icons.js",
    "autotranslate": "node ./utilities/autotranslate.js",
    "delete-keys": "node ./utilities/delete-keys.js",
    "prisma-chatbot-db:generate": "prisma --config ./prisma-chatbot-db/prisma-config.ts generate"
  },
