// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma-chatbot-db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Prompt {
  id      Int    @id @default(autoincrement())
  title   String
  orgCode String

  promptContents PromptContent[]

  @@unique([title, orgCode])
  @@index([title, orgCode])
}

model PromptContent {
  version Int
  content String

  promptId Int
  prompt   Prompt @relation(fields: [promptId], references: [id])

  agents Agent[]

  @@id([promptId, version])
  @@index([promptId, version])
}

model Skill {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  orgCode     String

  skillContents SkillContent[]

  @@unique([title, orgCode])
  @@index([title, orgCode])
}

model SkillContent {
  version Int
  content String

  skillId Int
  skill   Skill @relation(fields: [skillId], references: [id])

  agents AgentSkillContent[]

  @@id([skillId, version])
  @@index([skillId, version])
}

enum TransportType {
  sse
  stdio
  http
}

model Mcp {
  id          Int           @id @default(autoincrement())
  orgCode     String
  title       String
  description String
  transport   TransportType
  url         String
  command     String
  args        String

  agents Agent[]

  @@unique([title, orgCode])
}

model Agent {
  id          Int    @id @default(autoincrement())
  title       String
  slug        String
  description String @default("")
  orgCode     String

  modelName        String @default("")
  modelTemperature String @default("0.7")

  startMessage String @default("")

  isEnabled Boolean @default(false)

  promptId      Int
  promptVersion Int
  promptContent PromptContent @relation(fields: [promptId, promptVersion], references: [promptId, version])

  useProjectsMcp Boolean @default(false)
  mcps           Mcp[]

  skillContents AgentSkillContent[]

  documents AgentDocument[]

  useProfileData Boolean @default(false)

  useLatestPromptVersion Boolean @default(true)

  conversations  Conversation[]
  sideAssistants SideAssistant[]
  agentSlugAlias AgentSlugAlias[]

  @@unique([title, orgCode])
  @@unique([slug, orgCode])
  @@index([title, orgCode])
  @@index([slug, orgCode])
}

model AgentSlugAlias {
  slug    String
  orgCode String

  agentId Int
  agent   Agent @relation(fields: [agentId], references: [id])

  lastAccess DateTime?

  @@id([slug, agentId, orgCode])
  @@unique([slug, orgCode])
}

model AgentSkillContent {
  skillId      Int
  skillVersion Int
  agentId      Int

  useLatestSkillVersion Boolean @default(true)

  skillContent SkillContent @relation(fields: [skillId, skillVersion], references: [skillId, version])
  agent        Agent        @relation(fields: [agentId], references: [id])

  @@id([skillId, skillVersion, agentId])
}

model AgentDocument {
  vectorStoreKey String
  documentTitle  String
  agentId        Int
  isGlobal       Boolean @default(false)

  agent Agent @relation(fields: [agentId], references: [id])

  @@id([vectorStoreKey, documentTitle, agentId, isGlobal])
}

enum ConversationTitleSource {
  pending
  user
  llm
  fallback
}

model Conversation {
  id       String @id @default(uuid())
  threadId String @unique

  organizationCode String
  userId           Int

  agentId Int
  agent   Agent @relation(fields: [agentId], references: [id])

  startedAt    DateTime  @default(now())
  lastActiveAt DateTime  @updatedAt
  archivedAt   DateTime?

  title       String
  titleSource ConversationTitleSource @default(fallback)

  deletedAt DateTime?

  messages ConversationMessage[]

  @@index([organizationCode, userId])
  @@index([agentId, userId])
  @@index([organizationCode, agentId])
  @@index([deletedAt])
  @@index([archivedAt])
}

enum ConversationMessageRole {
  user
  assistant
  tool
  system
}

model ConversationMessage {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  role       ConversationMessageRole
  content    String
  toolCalls  Json?
  toolCallId String?
  createdAt  DateTime                @default(now())
  position   Int

  @@index([conversationId])
}

model SideAssistant {
  id      Int    @id @default(autoincrement())
  orgCode String
  agentId Int
  agent   Agent  @relation(fields: [agentId], references: [id])
}
