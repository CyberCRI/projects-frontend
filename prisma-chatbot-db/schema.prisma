// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma-chatbot-db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Prompt {
  id                Int @id @default(autoincrement())
  title             String
  orgCode           String

  promptContents    PromptContent[]

  @@unique([title, orgCode])
  @@index([title, orgCode])
}


model PromptContent {
  id                Int @id @default(autoincrement())
  version           Int
  content           String

  promptId          Int
  prompt            Prompt @relation(fields: [promptId], references: [id])

  agents            Agent[]

  @@unique([promptId, version])
  @@index([promptId, version])
}


model Agent {
  id                Int @id @default(autoincrement())
  title             String
  orgCode           String

  promptId          Int
  promptVersion     Int
  promptContent     PromptContent @relation(fields: [promptId, promptVersion], references: [promptId, version])

  useLatestPromptVersion Boolean @default(true)

  @@unique([title, orgCode])
  @@index([title, orgCode])
}
